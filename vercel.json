{
  "framework": "vite",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",

  "functions": {
    "api/ai/chat.py":  { "memory": 512,  "maxDuration": 30 },
    "api/ai/review.py": { "memory": 1024, "maxDuration": 60 },
    "api/**/*.go":     { "memory": 256,  "maxDuration": 30 }
  },

  "rewrites": [
    { "source": "/api/ai/chat",   "destination": "/api/ai/chat.py" },
    { "source": "/api/ai/review", "destination": "/api/ai/review.py" },

    { "source": "/api/auth/login",     "destination": "/api/auth?path=login" },
    { "source": "/api/auth/callback",  "destination": "/api/auth?path=callback" },
    { "source": "/api/auth/logout",    "destination": "/api/auth?path=logout" },
    { "source": "/api/auth/me",        "destination": "/api/auth?path=me" },
    { "source": "/api/auth/delete-account", "destination": "/api/auth?path=delete-account" },

    { "source": "/api/webhooks/campus-one", "destination": "/api/auth?path=webhook" },

    { "source": "/api/student/profile",         "destination": "/api/student?path=profile" },
    { "source": "/api/student/applications",    "destination": "/api/student?path=applications" },
    { "source": "/api/student/services",        "destination": "/api/student?path=services" },

    { "source": "/api/jobs/:id",                "destination": "/api/jobs?id=:id" },

    { "source": "/api/feed/:id/like",           "destination": "/api/feed?path=like&id=:id" },
    { "source": "/api/feed/:id/comments",       "destination": "/api/feed?path=comments&id=:id" },

    { "source": "/api/staff/dashboard",         "destination": "/api/staff?path=dashboard" },
    { "source": "/api/staff/applications",      "destination": "/api/staff?path=applications" },
    { "source": "/api/staff/jobs",              "destination": "/api/staff?path=jobs" },
    { "source": "/api/staff/employers",         "destination": "/api/staff?path=employers" },
    { "source": "/api/staff/students",          "destination": "/api/staff?path=students" },
    { "source": "/api/staff/student-detail",    "destination": "/api/staff?path=student-detail" },
    { "source": "/api/staff/service-requests",  "destination": "/api/staff?path=service-requests" },
    { "source": "/api/staff/cleanup",           "destination": "/api/staff?path=cleanup" },

    { "source": "/api/employer/profile",        "destination": "/api/employer?path=profile" },
    { "source": "/api/employer/jobs",           "destination": "/api/employer?path=jobs" },
    { "source": "/api/employer/applications",   "destination": "/api/employer?path=applications" },

    { "source": "/api/messages/conversations",  "destination": "/api/messages?path=conversations" },
    { "source": "/api/messages/thread/:toId",   "destination": "/api/messages?path=thread&toId=:toId" },
    { "source": "/api/messages/send/:toId",     "destination": "/api/messages?path=send&toId=:toId" },
    { "source": "/api/messages/presence",       "destination": "/api/messages?path=presence" },
    { "source": "/api/messages/typing/:toId",   "destination": "/api/messages?path=typing&toId=:toId" },

    { "source": "/api/users/search",            "destination": "/api/messages?path=users-search" },
    { "source": "/api/users/:id/presence",      "destination": "/api/messages?path=presence-status&userId=:id" },

    { "source": "/api/upload",                  "destination": "/api/messages?path=upload" },

    { "source": "/api/notifications",               "destination": "/api/messages?path=notifications" },
    { "source": "/api/notifications/unread-count",  "destination": "/api/messages?path=notifications-unread-count" },
    { "source": "/api/notifications/mark-all-read", "destination": "/api/messages?path=notifications-mark-all-read" },
    { "source": "/api/notifications/:id/read",      "destination": "/api/messages?path=notifications-read&id=:id" },

    { "source": "/api/connections",                 "destination": "/api/messages?path=connections" },
    { "source": "/api/connections/request/:toId",   "destination": "/api/messages?path=connections-request&toId=:toId" },
    { "source": "/api/connections/:id/respond",     "destination": "/api/messages?path=connections-respond&id=:id" },

    { "source": "/((?!api/).*)", "destination": "/index.html" }
  ],

  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, Authorization" }
      ]
    },
    {
      "source": "/assets/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
      ]
    }
  ]
}
