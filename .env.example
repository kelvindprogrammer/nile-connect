# ============================================================
# Nile Connect – Unified Environment Variables
# Copy this file to .env.local for local development.
# In Vercel, set these via the Dashboard → Project → Settings → Environment Variables.
# ============================================================

# ------------------------------------------------------------------
# Frontend (Vite) – prefix MUST be VITE_ to be exposed to the client
# ------------------------------------------------------------------

# URL of the deployed Go backend (e.g. Railway, Render, Fly.io)
# Leave empty to use relative /api paths (only works when running on Vercel)
VITE_API_BASE_URL=http://localhost:8080

# AI base URL – leave empty to use Vercel serverless functions at /api/ai/*
# Only set this if you're running the Python AI server separately
VITE_AI_BASE_URL=

# ------------------------------------------------------------------
# Backend (Go) – set in your backend deployment environment
# ------------------------------------------------------------------

PORT=8080
DATABASE_URL=postgres://username:password@localhost:5432/nile_connect
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRY_HOURS=24

# CORS – comma-separated list of allowed origins
# Add your Vercel deployment URL here (e.g. https://nile-connect.vercel.app)
ALLOWED_ORIGINS=http://localhost:5173,https://nile-connect.vercel.app

FILE_STORAGE_URL=/uploads

# ------------------------------------------------------------------
# AI Serverless Functions (Python / Vercel)
# ------------------------------------------------------------------

# Groq API key – get yours at https://console.groq.com
# In Vercel, create a secret named "groq_api_key" and it will be mapped automatically
GROQ_API_KEY=gsk_your_key_here
