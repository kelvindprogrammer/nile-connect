# ============================================================
# Nile Connect – Unified Environment Variables
# Copy this file to .env.local for local development.
# In Vercel, set these via the Dashboard → Project → Settings → Environment Variables.
# ============================================================

# ------------------------------------------------------------------
# Frontend (Vite) – prefix MUST be VITE_ to be exposed to the client
# ------------------------------------------------------------------

# Base URL for the app — used by the auth redirect flow.
# Leave empty when running on Vercel (same-origin API calls).
VITE_APP_URL=http://localhost:3000

# AI base URL – leave empty to use Vercel serverless functions at /api/ai/*
# Only set this if you're running the Python AI server separately
VITE_AI_BASE_URL=

# ------------------------------------------------------------------
# Campus One SSO (OIDC) — register your app at:
#   https://app.campusone.com.ng/developer/apps
# ------------------------------------------------------------------

# The Client ID shown in the Sign-in tab of your app drawer.
CAMPUS_ONE_CLIENT_ID=

# Click "Reveal" in the Sign-in tab to copy this. Treat it as a password.
# NEVER expose this to the browser or commit it to version control.
CAMPUS_ONE_CLIENT_SECRET=

# Found on the Webhooks tab. Rotate via "Rotate webhook secret" if leaked.
CAMPUS_ONE_WEBHOOK_SECRET=

# Redirect URL registered in the Campus One developer dashboard:
#   Local dev:  http://localhost:3000/api/auth/callback
#   Production: https://<your-app>.vercel.app/api/auth/callback
APP_URL=http://localhost:3000

# ------------------------------------------------------------------
# Session signing
# ------------------------------------------------------------------

# Secret key used to sign the nile_session httponly cookie.
# Generate with: openssl rand -hex 32
SESSION_SECRET=your-super-secret-session-key-change-in-production

# ------------------------------------------------------------------
# Database (Go) — set in your backend deployment environment
# ------------------------------------------------------------------

DATABASE_URL=postgres://username:password@localhost:5432/nile_connect

# CORS – comma-separated list of allowed origins
ALLOWED_ORIGINS=http://localhost:3000,https://nile-connect.vercel.app

# ------------------------------------------------------------------
# AI Serverless Functions (Python / Vercel)
# ------------------------------------------------------------------

# Groq API key – get yours at https://console.groq.com
# In Vercel, create a secret named "groq_api_key" and it will be mapped automatically
GROQ_API_KEY=gsk_your_key_here
